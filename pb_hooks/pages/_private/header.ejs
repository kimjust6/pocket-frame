<header
    @toggle-mobile-header.window="headerVisible = !headerVisible"
    x-show="headerVisible"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="-translate-y-full"
    x-transition:enter-end="translate-y-0"
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="translate-y-0"
    x-transition:leave-end="-translate-y-full"
    class="navbar fixed inset-x-0 top-0 z-50 border-b border-base-300 bg-base-100/80 shadow-sm backdrop-blur-md"
>
    <div class="container mx-auto flex w-full justify-between px-8 py-0">
        <!-- Logo / Mobile Title -->
        <div class="flex items-center gap-3">
            <a
                href="/"
                class="flex items-center gap-3 transition-opacity hover:opacity-80"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-6 w-6 text-primary"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <path
                        d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"
                    ></path>
                </svg>
                <div class="select-none leading-tight">
                    <p class="text-xl font-bold text-base-content lg:text-2xl">
                        Flame Startpage
                    </p>
                </div>
            </a>
        </div>

        <div class="hidden items-center gap-4 md:flex lg:gap-6">
            <!-- Navigation -->
            <template x-for="item in navigation" :key="item.title">
                <a
                    :href="item.href"
                    class="group relative text-sm font-medium tracking-wide text-base-content/80 transition-colors duration-200 hover:text-primary"
                    x-text="item.title"
                    x-show="item.desktop"
                >
                    <span
                        class="absolute -bottom-1 left-0 h-0.5 w-0 bg-primary transition-all duration-300 group-hover:w-full"
                    ></span>
                </a>
            </template>

            <%- include('theme-toggle.ejs') %> <% if (locals.auth) { %>
            <div
                class="dropdown dropdown-end"
                x-data="{ open: false }"
                :class="{ 'dropdown-open': open }"
                @click.outside="open = false"
            >
                <div
                    role="button"
                    class="avatar btn btn-circle btn-ghost"
                    @click="open = !open; if(!open) $el.blur()"
                >
                    <div
                        class="w-10 overflow-hidden rounded-full ring ring-primary ring-offset-2 ring-offset-base-100 transition-all duration-200 hover:ring-accent"
                    >
                        <% if (auth.getString('avatar')) { %>
                        <img
                            src="<%= '/api/files/' + auth.collection().id + '/' + auth.id + '/' + auth.getString('avatar') %>"
                            alt="User Avatar"
                            class="h-full w-full object-cover"
                        />
                        <% } else { %>
                        <span
                            class="flex h-full w-full items-center justify-center bg-neutral text-xl font-bold text-neutral-content"
                        >
                            <%= auth.email().slice(0, 1).toUpperCase() %>
                        </span>
                        <% } %>
                    </div>
                </div>
                <ul
                    tabindex="0"
                    class="menu dropdown-content menu-sm z-[1] mt-3 w-52 rounded-box bg-base-100 p-2 shadow"
                >
                    <li
                        class="menu-title px-4 py-2 text-xs text-base-content/50"
                    >
                        <%= auth.email() %>
                    </li>
                    <div class="divider my-1"></div>
                    <li><a href="/profile">Profile</a></li>
                    <li><a href="/settings">Settings</a></li>
                    <li><a href="/auth/logout">Logout</a></li>
                </ul>
            </div>
            <% } else { %>
            <a href="/login" class="btn btn-primary btn-sm">Login / Register</a>
            <% } %>
        </div>

        <!-- Mobile Menu Buttons -->
        <div class="flex items-center gap-2 md:hidden">
            <%- include('theme-toggle.ejs') %>

            <!-- Hamburger Menu Button -->
            <button
                class="btn btn-square btn-ghost text-base-content"
                @click="navOpen = !navOpen"
                aria-label="Toggle menu"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2"
                    stroke="currentColor"
                    class="h-6 w-6"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"
                    />
                </svg>
            </button>
        </div>
    </div>
</header>
