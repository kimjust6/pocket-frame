<div class="grid grid-cols-1 md:grid-cols-[1.1fr_1fr] min-h-screen bg-base-100">
    <!-- Left panel (Quote panel, visible on md and up) -->
    <div class="hidden md:flex flex-col justify-between p-14 bg-base-200 border-r border-base-content/10">
        <div class="flex items-center gap-2.5 text-lg font-bold text-base-content">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" class="text-brand-link">
                <path d="M6 2a2 2 0 0 0-2 2v18l8-5 8 5V4a2 2 0 0 0-2-2H6z"/>
            </svg>
            <span>Pocket Frame</span>
        </div>
        <div class="text-3xl font-serif leading-snug max-w-[420px] text-base-content">
            Every article, recipe, and idea worth keeping — <span class="text-brand-link italic font-serif">filed, not lost.</span>
        </div>
        <div class="text-xs text-base-content/50">
            Trusted by readers who never want to lose a link again.
        </div>
    </div>

    <!-- Right panel (Content/Form panel) -->
    <div class="flex items-center justify-center p-10 bg-base-100">
        <div class="w-full max-w-[380px] flex flex-col">
            <!-- Mobile Brand Header -->
            <div class="flex md:hidden items-center gap-2.5 text-base font-bold text-base-content mb-10">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="text-brand-link">
                    <path d="M6 2a2 2 0 0 0-2 2v18l8-5 8 5V4a2 2 0 0 0-2-2H6z"/>
                </svg>
                <span>Pocket Frame</span>
            </div>

            <p class="text-[12.5px] tracking-wider uppercase text-base-content/50 mb-2">
                <%= mode === 'login' ? 'Sign in' : 'Sign up' %>
            </p>
            <h1 class="text-3.5xl font-semibold text-base-content mb-2">
                <%= mode === 'login' ? 'Welcome back' : 'Create account' %>
            </h1>
            <p class="text-[15.5px] text-base-content/70 mb-8 leading-relaxed">
                <%= mode === 'login' ? 'Sign in to manage your bookmarks.' : 'Join us to manage your bookmarks.' %>
            </p>

            <!-- Google Sign-in Button Wrapper using dynamic Tailwind child utilities to match reference -->
            <div class="w-full [&_button]:btn [&_button]:btn-block [&_button]:bg-base-content [&_button]:text-base-100 [&_button]:border-none [&_button]:font-semibold [&_button]:text-[14.5px] [&_button]:py-3.5 [&_button]:h-auto [&_button]:normal-case [&_button]:rounded-lg [&_button:hover]:bg-base-content/90 [&_a]:btn [&_a]:btn-block [&_a]:bg-base-content [&_a]:text-base-100 [&_a]:border-none [&_a]:font-semibold [&_a]:text-[14.5px] [&_a]:py-3.5 [&_a]:h-auto [&_a]:normal-case [&_a]:rounded-lg [&_a:hover]:bg-base-content/90">
                <% var buttonText = mode === 'login' ? 'Continue with Google' : 'Sign up with Google' %>
                <% var fallbackError = mode === 'login' ? 'Unable to start Google login.' : 'Unable to start Google signup.' %>
                <%- include('oauth-google-start.ejs') %>
            </div>

            <div class="divider text-xs text-base-content/30 my-6">or</div>

            <div class="flex items-center justify-between mb-7">
                <a href="/" class="flex items-center gap-1.5 text-base-content/60 hover:text-base-content no-underline font-semibold text-[13.5px] transition-colors">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M15 18l-6-6 6-6"/>
                    </svg>
                    <span>Back to home</span>
                </a>
                <% if (mode === 'login') { %>
                    <a href="/register" class="flex items-center gap-1.5 text-brand-link hover:opacity-85 no-underline font-semibold text-[13.5px] transition-opacity">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                            <circle cx="9" cy="7" r="4"/>
                            <path d="M19 8v6M22 11h-6"/>
                        </svg>
                        <span>Create account</span>
                    </a>
                <% } else { %>
                    <a href="/login" class="flex items-center gap-1.5 text-brand-link hover:opacity-85 no-underline font-semibold text-[13.5px] transition-opacity">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4M10 17l5-5-5-5M13.8 12H3"/>
                        </svg>
                        <span>Login</span>
                    </a>
                <% } %>
            </div>

            <p class="text-xs text-base-content/50 leading-relaxed m-0 pt-5 border-t border-base-content/10">
                By signing <%= mode === 'login' ? 'in' : 'up' %>, you agree to our <a href="#" class="text-brand-link underline hover:opacity-80 transition-opacity">Terms of Service</a> and <a href="#" class="text-brand-link underline hover:opacity-80 transition-opacity">Privacy Policy</a>.
            </p>
        </div>
    </div>
</div>
