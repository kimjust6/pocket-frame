<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Dancing+Script:wght@700&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap"
    rel="stylesheet" />

<!-- PocketBase SDK (deferred to prevent render blocking) -->
<script src="https://unpkg.com/pocketbase@0.21.1/dist/pocketbase.umd.js" defer></script>

<%
const pageMetadata = (locals.data && locals.data.metadata) ? locals.data.metadata : [];
const defaultTitle = 'Pocket Frame';
const defaultDesc = 'Turn your tablet into a photo frame to display your photos. Pocket Frame is a self-hosted, lightweight slideshow and photo frame manager.';
const defaultUrl = 'https://link.jkim.win';
const defaultImage = defaultUrl + asset('/og-image.webp');

// Check if specific tags are defined in the provided metadata
const hasTitle = pageMetadata.some(tag => tag.name === 'title');
const hasDescription = pageMetadata.some(tag => tag.name === 'description');
const hasOgTitle = pageMetadata.some(tag => tag.name === 'og:title');
const hasOgDescription = pageMetadata.some(tag => tag.name === 'og:description');
const hasOgType = pageMetadata.some(tag => tag.name === 'og:type');
const hasOgUrl = pageMetadata.some(tag => tag.name === 'og:url');
const hasOgImage = pageMetadata.some(tag => tag.name === 'og:image');
const hasOgSiteName = pageMetadata.some(tag => tag.name === 'og:site_name');
const hasOgLocale = pageMetadata.some(tag => tag.name === 'og:locale');
const hasTwitterCard = pageMetadata.some(tag => tag.name === 'twitter:card');
const hasTwitterTitle = pageMetadata.some(tag => tag.name === 'twitter:title');
const hasTwitterDesc = pageMetadata.some(tag => tag.name === 'twitter:description');
const hasTwitterImage = pageMetadata.some(tag => tag.name === 'twitter:image');
%>

<!-- Default/Dynamic Metadata -->
<% if (!hasTitle) { %>
    <title><%= defaultTitle %></title>
<% } else { %>
    <title><%= pageMetadata.find(x => x.name === 'title').content %></title>
<% } %>

<% if (!hasDescription) { %>
    <meta name="description" content="<%= defaultDesc %>" />
<% } %>
<% if (!hasOgTitle) { %>
    <meta property="og:title" content="<%= defaultTitle %>" />
<% } %>
<% if (!hasOgDescription) { %>
    <meta property="og:description" content="<%= defaultDesc %>" />
<% } %>
<% if (!hasOgType) { %>
    <meta property="og:type" content="website" />
<% } %>
<% if (!hasOgUrl) { %>
    <meta property="og:url" content="<%= defaultUrl %>" />
<% } %>
<% if (!hasOgImage) { %>
    <meta property="og:image" content="<%= defaultImage %>" />
    <meta property="og:image:alt" content="Pocket Frame" />
    <meta property="og:image:width" content="637" />
    <meta property="og:image:height" content="425" />
<% } %>
<% if (!hasOgSiteName) { %>
    <meta property="og:site_name" content="Pocket Frame" />
<% } %>
<% if (!hasOgLocale) { %>
    <meta property="og:locale" content="en_US" />
<% } %>
<% if (!hasTwitterCard) { %>
    <meta name="twitter:card" content="summary_large_image" />
<% } %>
<% if (!hasTwitterTitle) { %>
    <meta name="twitter:title" content="<%= defaultTitle %>" />
<% } %>
<% if (!hasTwitterDesc) { %>
    <meta name="twitter:description" content="<%= defaultDesc %>" />
<% } %>
<% if (!hasTwitterImage) { %>
    <meta name="twitter:image" content="<%= defaultImage %>" />
<% } %>

<% pageMetadata.forEach(function(tag) { %>
    <% if (tag.name !== 'title') { %>
        <% 
        let content = tag.content;
        if ((tag.name === 'og:image' || tag.name === 'twitter:image') && content.endsWith('/og-image.webp')) {
            const base = content.substring(0, content.length - '/og-image.webp'.length);
            content = base + asset('/og-image.webp');
        }
        %>
        <% if (tag.name.startsWith('og:') || tag.name.startsWith('twitter:')) { %>
            <meta property="<%= tag.name %>" content="<%= content %>" />
        <% } else { %>
            <meta name="<%= tag.name %>" content="<%= content %>" />
        <% } %>
    <% } %>
<% }); %>

                            <link href="<%=asset('/app.css')%>" rel="stylesheet" />
                            <link rel="shortcut icon" type="image/x-icon" href="/favicon.ico" />
                             
                             <script>
                                 if ('serviceWorker' in navigator) {
                                     window.addEventListener('load', function() {
                                         navigator.serviceWorker.register('/sw.js').then(function(registration) {
                                             console.log('ServiceWorker registered with scope:', registration.scope);
                                         }).catch(function(err) {
                                             console.error('ServiceWorker registration failed:', err);
                                         });

                                         if ('caches' in window) {
                                             caches.open('pocket-frame-settings-cache').then(function(cache) {
                                                 cache.put('/settings.json', new Response(JSON.stringify({
                                                     cache_ttl: parseInt("<%= (locals.settings && typeof locals.settings.cache_ttl !== 'undefined') ? locals.settings.cache_ttl : 604800 %>", 10)
                                                 }), {
                                                     headers: { 'Content-Type': 'application/json' }
                                                 }));
                                             });
                                         }
                                     });
                                 }
                             </script>