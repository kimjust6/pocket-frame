<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Dancing+Script:wght@700&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap"
    rel="stylesheet" />

<!-- PocketBase SDK (deferred to prevent render blocking) -->
<script src="https://unpkg.com/pocketbase@0.21.1/dist/pocketbase.umd.js" defer></script>

<% if (data.metadata) { %>
    <% data.metadata.forEach(function(tag) { %>
        <% if (tag.name.startsWith('og:') || tag.name.startsWith('twitter:')) { %>
            <meta property="<%= tag.name %>" content="<%= tag.content %>" />
            <% } else { %>
                <meta name="<%= tag.name %>" content="<%= tag.content %>" />
                <% } %>
                    <% }); %>
                        <% } %>

                            <title>
                                <%= data.metadata?.find(x=> x.name === 'title')?.content || 'Pocket Frame' %>
                            </title>

                            <link href="<%=asset('/app.css')%>" rel="stylesheet" />
                            <link rel="shortcut icon" type="image/x-icon" href="/favicon.ico" />
                             
                             <script>
                                 if ('serviceWorker' in navigator) {
                                     window.addEventListener('load', function() {
                                         navigator.serviceWorker.register('/sw.js').then(function(registration) {
                                             console.log('ServiceWorker registered with scope:', registration.scope);
                                         }).catch(function(err) {
                                             console.error('ServiceWorker registration failed:', err);
                                         });

                                         if ('caches' in window) {
                                             caches.open('pocket-frame-settings-cache').then(function(cache) {
                                                 cache.put('/settings.json', new Response(JSON.stringify({
                                                     cache_ttl: <%= (locals.settings && typeof locals.settings.cache_ttl !== 'undefined') ? locals.settings.cache_ttl : 604800 %>
                                                 }), {
                                                     headers: { 'Content-Type': 'application/json' }
                                                 }));
                                             });
                                         }
                                     });
                                 }
                             </script>