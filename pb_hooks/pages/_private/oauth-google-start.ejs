<% var buttonText = typeof locals.buttonText === 'string' ? locals.buttonText :
'Continue with Google' %> <% var fallbackError = typeof locals.fallbackError ===
'string' ? locals.fallbackError : 'Unable to start Google login.' %>

<div id="oauth-error" class="alert alert-error hidden text-sm"></div>

<button
    type="button"
    id="google-login-btn"
    class="btn btn-primary btn-lg w-full gap-3 shadow-lg transition-all hover:scale-[1.02] hover:shadow-primary/30"
    onclick="startGoogleOAuth(event)"
>
    <svg class="h-6 w-6" viewBox="0 0 24 24">
        <path
            fill="currentColor"
            d="M21.35 11.1h-9.17v2.73h6.51c-.33 3.81-3.5 5.44-6.5 5.44C8.36 19.27 5 16.25 5 12c0-4.1 3.2-7.27 7.16-7.27 1.94 0 3.73.53 5.3 2.07l1.96-1.96C16.91 2.97 14.76 2 12.16 2 6.6 2 2.08 6.53 2.08 12.2S6.6 22.41 12.16 22.41c4.42 0 8.12-2.31 9.75-5.9 1.16-2.55 1.16-5.41.93-5.41z"
        />
    </svg>
    <span><%= buttonText %></span>
</button>

<script>
    async function startGoogleOAuth(event) {
        event.preventDefault()

        const errorEl = document.getElementById('oauth-error')
        const button = document.getElementById('google-login-btn')

        const showError = (msg) => {
            if (!errorEl) return
            errorEl.textContent = msg
            errorEl.classList.remove('hidden')
        }

        try {
            if (button) button.setAttribute('disabled', 'disabled')
            if (errorEl) {
                errorEl.textContent = ''
                errorEl.classList.add('hidden')
            }

            const methodsRes = await fetch(
                '/api/collections/users/auth-methods'
            )
            if (!methodsRes.ok) {
                throw new Error('Unable to load OAuth providers.')
            }

            const methods = await methodsRes.json()
            const providers =
                methods &&
                methods.oauth2 &&
                Array.isArray(methods.oauth2.providers)
                    ? methods.oauth2.providers
                    : []
            const provider = providers.find((p) => p.name === 'google')

            if (!provider) {
                throw new Error('Google provider is not configured.')
            }

            const isProdHost =
                window.location.hostname === 'frame.jkim.win' 
            const canonicalOrigin = isProdHost
                ? 'https://frame.jkim.win'
                : window.location.origin
            const redirectURL = canonicalOrigin + '/auth/oauth/redirect'
            const authUrl = provider.authURL + encodeURIComponent(redirectURL)

            localStorage.setItem(
                'pp_oauth_state',
                JSON.stringify({
                    name: provider.name,
                    state: provider.state,
                    codeVerifier: provider.codeVerifier,
                    redirectURL,
                })
            )

            window.location.assign(authUrl)
        } catch (err) {
            showError(err && err.message ? err.message : '<%= fallbackError %>')
            if (button) button.removeAttribute('disabled')
        }
    }
</script>
