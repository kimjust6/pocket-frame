<% if (locals.data && (locals.data.success || locals.data.error)) { -%><%- JSON.stringify(locals.data) -%><% return; } -%>
<div
    x-data="settingsManager()"
    class="mx-auto min-h-screen max-w-3xl px-4 py-8"
>
    <div
        class="border-[color:var(--color-primary)]/10 mb-8 flex items-center justify-between border-b pb-4"
    >
        <a
            href="/"
            class="btn btn-ghost btn-sm -ml-1 pl-0 text-xs hover:text-[color:var(--color-accent)]"
        >
            Back to Slideshow
        </a>
        <h1 class="text-xl font-extrabold tracking-tight">
            Slideshow Settings
        </h1>
    </div>

    <form
        @submit.prevent="saveSettings"
        class="bg-[color:var(--color-primary)]/3 border-[color:var(--color-primary)]/10 space-y-6 rounded-xl border p-6"
    >
        <!-- Albums Management Section -->
        <div class="space-y-4">
            <div class="flex justify-between items-center border-b border-[color:var(--color-primary)]/10 pb-2">
                <h2 class="text-base font-bold text-[color:var(--color-accent)]">
                    Albums & Sources
                </h2>
                <button
                    type="button"
                    @click="startAddAlbum()"
                    class="btn btn-accent btn-xs rounded-lg px-3 font-semibold text-[color:var(--color-background)] hover:opacity-90"
                    :disabled="isAddingAlbum || editingAlbumId"
                >
                    + Add Album
                </button>
            </div>

            <!-- Empty state warning -->
            <div x-show="albums.length === 0" class="alert alert-warning text-xs rounded-lg p-3">
                <span>You must add at least one album to display a slideshow.</span>
            </div>

            <!-- Albums List -->
            <div class="space-y-3">
                <template x-for="(album, idx) in albums" :key="album.id">
                    <div
                        class="border-[color:var(--color-primary)]/10 bg-[color:var(--color-primary)]/2 rounded-xl border p-4 transition-all relative hover:border-[color:var(--color-primary)]/20"
                        :class="settings.active_album === album.id ? 'border-[color:var(--color-accent)]/30 bg-[color:var(--color-accent)]/2' : ''"
                    >
                        <!-- VIEW MODE -->
                        <div x-show="editingAlbumId !== album.id" class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                            <div class="space-y-1.5 flex-1 min-w-0">
                                <div class="flex items-center gap-2 flex-wrap">
                                    <!-- Sort Buttons -->
                                    <div class="flex items-center gap-0.5 mr-1" x-show="albums.length > 1 && editingAlbumId !== album.id">
                                        <button
                                            type="button"
                                            @click="moveAlbumUp(idx)"
                                            class="btn btn-ghost btn-xs p-0 w-5 h-5 min-h-0 hover:text-[color:var(--color-accent)]"
                                            :class="idx === 0 ? 'opacity-25 pointer-events-none' : ''"
                                            title="Move Up"
                                        >
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 15l7-7 7 7" />
                                            </svg>
                                        </button>
                                        <button
                                            type="button"
                                            @click="moveAlbumDown(idx)"
                                            class="btn btn-ghost btn-xs p-0 w-5 h-5 min-h-0 hover:text-[color:var(--color-accent)]"
                                            :class="idx === albums.length - 1 ? 'opacity-25 pointer-events-none' : ''"
                                            title="Move Down"
                                        >
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7" />
                                            </svg>
                                        </button>
                                    </div>
                                    <span class="text-sm font-bold text-base-content tracking-tight" x-text="album.name"></span>
                                    <template x-if="settings.active_album === album.id">
                                        <span class="badge badge-accent badge-sm font-bold px-2 text-[10px] text-[color:var(--color-background)]">Active</span>
                                    </template>
                                </div>
                                <div class="space-y-0.5 text-xs opacity-75">
                                    <div class="flex items-center gap-1.5 overflow-hidden">
                                        <span class="font-semibold uppercase text-[9px] opacity-50 flex-shrink-0 w-24">Immich Share:</span>
                                        <span class="truncate" x-text="album.immich_url || 'None'"></span>
                                    </div>
                                    <template x-if="album.fallback_urls && album.fallback_urls.length > 0">
                                        <div class="space-y-0.5">
                                            <template x-for="(url, uIdx) in album.fallback_urls" :key="uIdx">
                                                <div class="flex items-center gap-1.5 overflow-hidden">
                                                    <span class="font-semibold uppercase text-[9px] opacity-50 flex-shrink-0 w-24" x-text="url.includes('amazon') || url.includes('/photos/share/') ? 'Amazon Fallback:' : (url.includes('google') || url.includes('goo.gl') ? 'Google Fallback:' : 'Fallback:')"></span>
                                                    <span class="truncate text-[11px]" x-text="url"></span>
                                                </div>
                                            </template>
                                        </div>
                                    </template>
                                    <template x-if="!album.fallback_urls || album.fallback_urls.length === 0">
                                        <div class="flex items-center gap-1.5 overflow-hidden">
                                            <span class="font-semibold uppercase text-[9px] opacity-50 flex-shrink-0 w-24">Fallbacks:</span>
                                            <span class="truncate opacity-50">None</span>
                                        </div>
                                    </template>
                                </div>
                            </div>
                            <div class="flex items-center gap-2 flex-shrink-0">
                                <button
                                    type="button"
                                    @click="startEditAlbum(album)"
                                    class="btn btn-ghost btn-xs text-xs font-semibold hover:text-[color:var(--color-accent)]"
                                    :disabled="isAddingAlbum || editingAlbumId"
                                >
                                    Edit
                                </button>
                                <button
                                    type="button"
                                    @click="deleteAlbum(album.id)"
                                    class="btn btn-ghost btn-xs text-xs font-semibold hover:text-error"
                                    :disabled="isAddingAlbum || editingAlbumId"
                                >
                                    Delete
                                </button>
                                <button
                                    type="button"
                                    x-show="settings.active_album !== album.id"
                                    @click="setActiveAlbum(album.id)"
                                    class="btn btn-accent btn-xs rounded font-semibold text-[color:var(--color-background)]"
                                    :disabled="isAddingAlbum || editingAlbumId"
                                >
                                    Set Active
                                </button>
                            </div>
                        </div>

                        <!-- EDIT MODE -->
                        <div x-show="editingAlbumId === album.id" class="space-y-4">
                            <div class="grid grid-cols-1 gap-3">
                                <div>
                                    <label class="mb-1 block text-[10px] font-semibold uppercase opacity-65">Album Name</label>
                                    <input
                                        type="text"
                                        x-model="editingAlbumData.name"
                                        class="border-[color:var(--color-primary)]/10 input input-xs input-bordered w-full bg-transparent text-base-content"
                                        placeholder="e.g. Living Room Frame"
                                    />
                                </div>
                                <div>
                                    <label class="mb-1 block text-[10px] font-semibold uppercase opacity-65">Immich Share URL</label>
                                    <input
                                        type="text"
                                        x-model="editingAlbumData.immich_url"
                                        class="border-[color:var(--color-primary)]/10 input input-xs input-bordered w-full bg-transparent text-base-content"
                                        placeholder="https://photos.example.com/share/..."
                                    />
                                </div>
                                <div class="space-y-2">
                                    <label class="block text-[10px] font-semibold uppercase opacity-65">Fallback URLs (Amazon or Google Photos)</label>
                                    <div class="space-y-2">
                                        <template x-for="(item, index) in editingAlbumData.fallback_urls" :key="item.id">
                                            <div class="flex gap-2 items-center">
                                                <span class="text-xs opacity-50 font-mono w-5 select-none" x-text="index + 1"></span>
                                                <div class="flex items-center gap-0.5" x-show="editingAlbumData.fallback_urls.length > 1">
                                                    <button
                                                        type="button"
                                                        @click="moveFallbackUp(editingAlbumData.fallback_urls, index)"
                                                        class="btn btn-ghost btn-xs p-0 w-5 h-5 min-h-0 hover:text-[color:var(--color-accent)]"
                                                        :class="index === 0 ? 'opacity-25 pointer-events-none' : ''"
                                                        title="Move Up"
                                                    >
                                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 15l7-7 7 7" />
                                                        </svg>
                                                    </button>
                                                    <button
                                                        type="button"
                                                        @click="moveFallbackDown(editingAlbumData.fallback_urls, index)"
                                                        class="btn btn-ghost btn-xs p-0 w-5 h-5 min-h-0 hover:text-[color:var(--color-accent)]"
                                                        :class="index === editingAlbumData.fallback_urls.length - 1 ? 'opacity-25 pointer-events-none' : ''"
                                                        title="Move Down"
                                                    >
                                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7" />
                                                        </svg>
                                                    </button>
                                                </div>
                                                <input
                                                    type="text"
                                                    x-model="item.url"
                                                    class="border-[color:var(--color-primary)]/10 input input-xs input-bordered w-full bg-transparent text-base-content"
                                                    placeholder="https://www.amazon.ca/photos/share/... or https://photos.google.com/share/..."
                                                />
                                                <button
                                                    type="button"
                                                    @click="editingAlbumData.fallback_urls.splice(index, 1)"
                                                    class="btn btn-ghost btn-xs text-error font-semibold hover:bg-error/10"
                                                >
                                                    Remove
                                                </button>
                                            </div>
                                        </template>
                                    </div>
                                    <button
                                        type="button"
                                        @click="editingAlbumData.fallback_urls.push({ id: Date.now() + '_' + Math.random(), url: '' })"
                                        class="btn btn-ghost btn-xs text-xs font-semibold hover:text-[color:var(--color-accent)] pl-0"
                                    >
                                        + Add Fallback URL
                                    </button>
                                </div>
                            </div>
                            <div class="flex justify-end gap-2">
                                <button
                                    type="button"
                                    @click="cancelEditAlbum()"
                                    class="btn btn-ghost btn-xs font-semibold"
                                >
                                    Cancel
                                </button>
                                <button
                                    type="button"
                                    @click="saveEditAlbum()"
                                    class="btn btn-accent btn-xs rounded font-semibold text-[color:var(--color-background)]"
                                >
                                    Save Changes
                                </button>
                            </div>
                        </div>
                    </div>
                </template>

                <!-- ADD ALBUM INLINE CARD -->
                <div
                    x-show="isAddingAlbum"
                    class="border-[color:var(--color-accent)]/20 bg-[color:var(--color-primary)]/2 rounded-xl border border-dashed p-4 space-y-4"
                >
                    <div class="text-xs font-bold text-[color:var(--color-accent)] uppercase tracking-wider">
                        New Album Configuration
                    </div>
                    <div class="grid grid-cols-1 gap-3">
                        <div>
                            <label class="mb-1 block text-[10px] font-semibold uppercase opacity-65">Album Name</label>
                            <input
                                type="text"
                                x-model="newAlbumData.name"
                                class="border-[color:var(--color-primary)]/10 input input-xs input-bordered w-full bg-transparent text-base-content"
                                placeholder="e.g. Vacation Slideshow"
                            />
                        </div>
                        <div>
                            <label class="mb-1 block text-[10px] font-semibold uppercase opacity-65">Immich Share URL</label>
                            <input
                                type="text"
                                x-model="newAlbumData.immich_url"
                                class="border-[color:var(--color-primary)]/10 input input-xs input-bordered w-full bg-transparent text-base-content"
                                placeholder="https://photos.example.com/share/..."
                            />
                        </div>
                        <div class="space-y-2">
                            <label class="block text-[10px] font-semibold uppercase opacity-65">Fallback URLs (Amazon or Google Photos)</label>
                            <div class="space-y-2">
                                <template x-for="(item, index) in newAlbumData.fallback_urls" :key="item.id">
                                    <div class="flex gap-2 items-center">
                                        <span class="text-xs opacity-50 font-mono w-5 select-none" x-text="index + 1"></span>
                                        <div class="flex items-center gap-0.5" x-show="newAlbumData.fallback_urls.length > 1">
                                            <button
                                                type="button"
                                                @click="moveFallbackUp(newAlbumData.fallback_urls, index)"
                                                class="btn btn-ghost btn-xs p-0 w-5 h-5 min-h-0 hover:text-[color:var(--color-accent)]"
                                                :class="index === 0 ? 'opacity-25 pointer-events-none' : ''"
                                                title="Move Up"
                                            >
                                                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 15l7-7 7 7" />
                                                </svg>
                                            </button>
                                            <button
                                                type="button"
                                                @click="moveFallbackDown(newAlbumData.fallback_urls, index)"
                                                class="btn btn-ghost btn-xs p-0 w-5 h-5 min-h-0 hover:text-[color:var(--color-accent)]"
                                                :class="index === newAlbumData.fallback_urls.length - 1 ? 'opacity-25 pointer-events-none' : ''"
                                                title="Move Down"
                                            >
                                                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7" />
                                                </svg>
                                            </button>
                                        </div>
                                        <input
                                            type="text"
                                            x-model="item.url"
                                            class="border-[color:var(--color-primary)]/10 input input-xs input-bordered w-full bg-transparent text-base-content"
                                            placeholder="https://www.amazon.ca/photos/share/... or https://photos.google.com/share/..."
                                        />
                                        <button
                                            type="button"
                                            @click="newAlbumData.fallback_urls.splice(index, 1)"
                                            class="btn btn-ghost btn-xs text-error font-semibold hover:bg-error/10"
                                        >
                                            Remove
                                        </button>
                                    </div>
                                </template>
                            </div>
                            <button
                                type="button"
                                @click="newAlbumData.fallback_urls.push({ id: Date.now() + '_' + Math.random(), url: '' })"
                                class="btn btn-ghost btn-xs text-xs font-semibold hover:text-[color:var(--color-accent)] pl-0"
                            >
                                + Add Fallback URL
                            </button>
                        </div>
                    </div>
                    <div class="flex justify-end gap-2">
                        <button
                            type="button"
                            @click="cancelAddAlbum()"
                            class="btn btn-ghost btn-xs font-semibold"
                        >
                            Cancel
                        </button>
                        <button
                            type="button"
                            @click="saveNewAlbum()"
                            class="btn btn-accent btn-xs rounded font-semibold text-[color:var(--color-background)]"
                        >
                            Create Album
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="divider opacity-10"></div>

        <h2 class="text-base font-bold text-[color:var(--color-accent)]">
            Slideshow Options
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 bg-[color:var(--color-primary)]/5 border border-[color:var(--color-primary)]/10 rounded-lg p-4">
            <div class="flex items-center gap-3">
                <input
                    type="checkbox"
                    x-model="settings.randomize"
                    id="randomize"
                    class="checkbox checkbox-sm checkbox-accent rounded"
                />
                <label for="randomize" class="text-sm font-semibold cursor-pointer select-none">
                    Randomize order
                </label>
            </div>
            <div class="flex items-center gap-3">
                <input
                    type="checkbox"
                    x-model="settings.prioritize_videos"
                    id="prioritize_videos"
                    class="checkbox checkbox-sm checkbox-accent rounded"
                />
                <label for="prioritize_videos" class="text-sm font-semibold cursor-pointer select-none">
                    Prioritize videos
                </label>
            </div>
            <div class="flex items-center gap-3">
                <input
                    type="checkbox"
                    x-model="settings.autoplay_fullscreen"
                    id="autoplay_fullscreen"
                    class="checkbox checkbox-sm checkbox-accent rounded"
                />
                <label for="autoplay_fullscreen" class="text-sm font-semibold cursor-pointer select-none">
                    Autoplay fullscreen
                </label>
            </div>
        </div>

        <div class="divider opacity-10"></div>

        <h2 class="text-base font-bold text-[color:var(--color-accent)]">
            Slideshow Tuning
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 bg-[color:var(--color-primary)]/5 border border-[color:var(--color-primary)]/10 rounded-lg p-4">
            <div class="flex items-center justify-between md:justify-start gap-4">
                <label for="latest_pin_count" class="text-sm font-semibold">
                    Pin newest items to front:
                </label>
                <div class="flex items-center gap-2">
                    <input
                        type="number"
                        x-model.number="settings.latest_pin_count"
                        id="latest_pin_count"
                        min="0"
                        placeholder="6"
                        class="border-[color:var(--color-primary)]/10 input input-sm input-bordered w-20 bg-transparent text-center"
                    />
                    <span class="text-xs opacity-60 font-semibold">items</span>
                </div>
            </div>
            <div class="flex items-center justify-between md:justify-start gap-4">
                <label for="slide_interval" class="text-sm font-semibold">
                    Slide transition duration:
                </label>
                <div class="flex items-center gap-2">
                    <input
                        type="number"
                        x-model.number="settings.slide_interval"
                        id="slide_interval"
                        min="1"
                        placeholder="7"
                        class="border-[color:var(--color-primary)]/10 input input-sm input-bordered w-20 bg-transparent text-center"
                    />
                    <span class="text-xs opacity-60 font-semibold">seconds</span>
                </div>
            </div>
        </div>

        <div class="divider opacity-10"></div>

        <h2 class="text-base font-bold text-[color:var(--color-accent)]">
            Video Settings
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 bg-[color:var(--color-primary)]/5 border border-[color:var(--color-primary)]/10 rounded-lg p-4">
            <div class="flex items-center justify-between md:justify-start gap-4">
                <label for="video_repeat_threshold" class="text-sm font-semibold">
                    Repeat videos shorter than:
                </label>
                <div class="flex items-center gap-2">
                    <input
                        type="number"
                        x-model.number="settings.video_repeat_threshold"
                        id="video_repeat_threshold"
                        min="0"
                        placeholder="5"
                        class="border-[color:var(--color-primary)]/10 input input-sm input-bordered w-20 bg-transparent text-center"
                    />
                    <span class="text-xs opacity-60 font-semibold">seconds</span>
                </div>
            </div>
            <div class="flex items-center justify-between md:justify-start gap-4">
                <label for="video_repeat_count" class="text-sm font-semibold">
                    Repeat count:
                </label>
                <div class="flex items-center gap-2">
                    <input
                        type="number"
                        x-model.number="settings.video_repeat_count"
                        id="video_repeat_count"
                        min="1"
                        placeholder="3"
                        class="border-[color:var(--color-primary)]/10 input input-sm input-bordered w-20 bg-transparent text-center"
                    />
                    <span class="text-xs opacity-60 font-semibold">times</span>
                </div>
            </div>
        </div>

        <div class="divider opacity-10"></div>

        <h2 class="text-base font-bold text-[color:var(--color-accent)]">
            Theme
        </h2>
        <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
            <div>
                <label
                    class="mb-2 block text-xs font-semibold uppercase opacity-60"
                    >Primary Color</label
                >
                <div class="flex gap-2">
                    <input
                        type="color"
                        x-model="settings.color_primary"
                        class="border-[color:var(--color-primary)]/10 h-10 w-10 cursor-pointer rounded border bg-transparent"
                    />
                    <input
                        type="text"
                        x-model="settings.color_primary"
                        class="border-[color:var(--color-primary)]/10 input input-sm input-bordered w-full bg-transparent"
                    />
                </div>
            </div>

            <div>
                <label
                    class="mb-2 block text-xs font-semibold uppercase opacity-60"
                    >Accent Color</label
                >
                <div class="flex gap-2">
                    <input
                        type="color"
                        x-model="settings.color_accent"
                        class="border-[color:var(--color-primary)]/10 h-10 w-10 cursor-pointer rounded border bg-transparent"
                    />
                    <input
                        type="text"
                        x-model="settings.color_accent"
                        class="border-[color:var(--color-primary)]/10 input input-sm input-bordered w-full bg-transparent"
                    />
                </div>
            </div>

            <div>
                <label
                    class="mb-2 block text-xs font-semibold uppercase opacity-60"
                    >Background Color</label
                >
                <div class="flex gap-2">
                    <input
                        type="color"
                        x-model="settings.color_background"
                        class="border-[color:var(--color-primary)]/10 h-10 w-10 cursor-pointer rounded border bg-transparent"
                    />
                    <input
                        type="text"
                        x-model="settings.color_background"
                        class="border-[color:var(--color-primary)]/10 input input-sm input-bordered w-full bg-transparent"
                    />
                </div>
            </div>
        </div>

        <div class="divider opacity-10"></div>

        <h2 class="text-base font-bold text-[color:var(--color-accent)]">
            Cache Management
        </h2>
        <p class="text-xs opacity-70">
            Images are cached locally in your browser for offline use and faster slideshow loading.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 bg-[color:var(--color-primary)]/5 border border-[color:var(--color-primary)]/10 rounded-lg p-4">
            <div class="flex items-center justify-between md:justify-start gap-4">
                <label for="cache_ttl" class="text-sm font-semibold">
                    Image cache duration:
                </label>
                <div class="flex items-center gap-2">
                    <input
                        type="number"
                        x-model.number="cacheTtlDays"
                        id="cache_ttl"
                        min="1"
                        placeholder="7"
                        class="border-[color:var(--color-primary)]/10 input input-sm input-bordered w-20 bg-transparent text-center"
                    />
                    <span class="text-xs opacity-60 font-semibold">days</span>
                </div>
            </div>

            <div class="flex items-center justify-between md:justify-start gap-4">
                <div class="flex items-center gap-4 w-full">
                    <button
                        type="button"
                        @click="clearCache()"
                        class="btn btn-error btn-sm btn-outline rounded-lg px-4 font-semibold"
                        :class="{ 'loading': clearingCache }"
                        :disabled="clearingCache"
                    >
                        Clear Browser Image Cache
                    </button>
                    <span class="text-xs opacity-50" x-text="cacheSizeText">Checking storage...</span>
                </div>
            </div>
        </div>

        <div class="flex justify-end gap-3 pt-4">
            <button
                type="button"
                @click="applySettings()"
                class="btn btn-accent btn-outline btn-sm rounded-lg px-6 font-bold"
            >
                Apply
            </button>
            <button
                type="submit"
                class="btn btn-accent btn-sm rounded-lg px-6 font-bold text-[color:var(--color-background)]"
            >
                Save Settings
            </button>
        </div>
    </form>

    <div class="toast toast-end toast-bottom z-[100]">
        <template x-for="toast in toasts" :key="toast.id">
            <div :class="`alert ${toastAlertClass(toast.type)} shadow-lg`">
                <span x-text="toast.message"></span>
                <button
                    @click="removeToast(toast.id)"
                    class="btn btn-ghost btn-xs"
                >
                    x
                </button>
            </div>
        </template>
    </div>
</div>

<script id="settings-data" type="application/json">
    <%- JSON.stringify({
        settings: data.settings || {},
        albums: data.albums || [],
        userId: locals.auth ? locals.auth.id : ""
    }) %>
</script>

<script src="/js/toast-helper.js"></script>
<script>
    function settingsManager() {
        const dataEl = document.getElementById('settings-data');
        const settingsData = dataEl ? JSON.parse(dataEl.textContent) : {};

        return window.withToastHelpers({
            settings: settingsData.settings || {},
            albums: settingsData.albums || [],
            userId: settingsData.userId || '',
            pb: null,
            clearingCache: false,
            cacheSizeText: 'Checking cache...',
            cacheTtlDays: 7,

            isAddingAlbum: false,
            newAlbumData: { name: '', immich_url: '', amazon_url: '', fallback_urls: [] },
            editingAlbumId: null,
            editingAlbumData: { name: '', immich_url: '', amazon_url: '', fallback_urls: [] },

            init() {
                this.updateCacheSize();
                this.cacheTtlDays = Math.round((this.settings.cache_ttl || 604800) / 86400);
            },

            async postAction(action, data = {}) {
                const params = new URLSearchParams();
                params.append('action', action);
                for (const key in data) {
                    if (data[key] !== undefined && data[key] !== null) {
                        params.append(key, typeof data[key] === 'object' ? JSON.stringify(data[key]) : data[key]);
                    }
                }
                const res = await fetch('/settings', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: params.toString()
                });

                if (res.redirected && res.url && res.url.includes('/login')) {
                    window.location.href = '/login';
                    return;
                }

                const contentType = res.headers.get('content-type') || '';
                if (!contentType.includes('application/json')) {
                    if (res.url && res.url.includes('/login')) {
                        window.location.href = '/login';
                        return;
                    }
                    throw new Error('Session expired or invalid server response format.');
                }

                if (!res.ok) {
                    const errText = await res.text();
                    let errJson;
                    try { errJson = JSON.parse(errText); } catch(_) {}
                    throw new Error((errJson && errJson.error) || errText || 'Server error');
                }
                return res.json();
            },

            async updateCacheSize() {
                try {
                    if ('caches' in window) {
                        const cache = await caches.open('pocket-frame-image-cache-v1');
                        const keys = await cache.keys();
                        this.cacheSizeText = `${keys.length} image(s) cached`;
                    } else {
                        this.cacheSizeText = 'Browser caching not supported';
                    }
                } catch (e) {
                    this.cacheSizeText = 'Unable to check cache';
                }
            },

            async clearCache() {
                if (this.clearingCache) return;
                this.clearingCache = true;
                try {
                    if ('caches' in window) {
                        const deleted = await caches.delete('pocket-frame-image-cache-v1');
                        if (deleted) {
                            this.showToast('Browser image cache cleared successfully!', 'success');
                        } else {
                            this.showToast('No cache found to clear.', 'info');
                        }
                    } else {
                        this.showToast('Browser cache is not supported by your browser.', 'warning');
                    }
                    await this.updateCacheSize();
                } catch (e) {
                    this.showToast('Error clearing cache: ' + e.message, 'error');
                } finally {
                    this.clearingCache = false;
                }
            },

            extractUrlCandidate(rawValue) {
                if (typeof rawValue !== 'string') return '';
                const trimmed = rawValue.trim();
                if (!trimmed) return '';

                const markdown = trimmed.match(/^\[[^\]]+\]\((https?:\/\/[^\s)]+)\)$/i);
                return markdown && markdown[1] ? markdown[1].trim() : trimmed;
            },

            normalizeHttpUrl(rawValue) {
                const candidate = this.extractUrlCandidate(rawValue);
                if (!candidate) return '';

                const withScheme = /^[a-zA-Z][a-zA-Z\d+\-.]*:\/\//.test(candidate)
                    ? candidate
                    : `https://${candidate}`;

                try {
                    const parsed = new URL(withScheme);
                    if (parsed.protocol !== 'http:' && parsed.protocol !== 'https:') {
                        return '';
                    }
                    return parsed.toString();
                } catch (_) {
                    return '';
                }
            },

            startAddAlbum() {
                this.isAddingAlbum = true;
                this.newAlbumData = { name: '', immich_url: '', amazon_url: '', fallback_urls: [] };
                this.editingAlbumId = null;
            },

            cancelAddAlbum() {
                this.isAddingAlbum = false;
            },

            async saveNewAlbum() {
                if (!this.newAlbumData.name.trim()) {
                    this.showToast('Please enter an album name.', 'warning');
                    return;
                }
                let normalizedImmich = '';
                if (this.newAlbumData.immich_url && this.newAlbumData.immich_url.trim()) {
                    normalizedImmich = this.normalizeHttpUrl(this.newAlbumData.immich_url);
                    if (!normalizedImmich) {
                        this.showToast('Please enter a valid Immich share URL.', 'warning');
                        return;
                    }
                }
                let normalizedFallbacks = [];
                if (this.newAlbumData.fallback_urls && this.newAlbumData.fallback_urls.length > 0) {
                    for (const item of this.newAlbumData.fallback_urls) {
                        const rawUrl = item ? item.url : '';
                        if (rawUrl && rawUrl.trim()) {
                            const normalized = this.normalizeHttpUrl(rawUrl);
                            if (!normalized) {
                                this.showToast('Invalid fallback URL found: ' + rawUrl, 'warning');
                                return;
                            }
                            normalizedFallbacks.push(normalized);
                        }
                    }
                }
                if (!normalizedImmich && normalizedFallbacks.length === 0) {
                    this.showToast('Please enter an Immich share URL or at least one fallback URL.', 'warning');
                    return;
                }
                const firstAmz = normalizedFallbacks.find(u => u.includes('amazon') || u.includes('/photos/share/')) || '';

                try {
                    const result = await this.postAction('create_album', {
                        name: this.newAlbumData.name.trim(),
                        immich_url: normalizedImmich,
                        amazon_url: firstAmz || (normalizedFallbacks[0] || ''),
                        fallback_urls: normalizedFallbacks,
                        order: this.albums.length
                    });
                    
                    this.albums.push({
                        id: result.id,
                        name: this.newAlbumData.name.trim(),
                        immich_url: normalizedImmich,
                        amazon_url: firstAmz || (normalizedFallbacks[0] || ''),
                        fallback_urls: normalizedFallbacks,
                        order: this.albums.length
                    });

                    if (this.albums.length === 1 || !this.settings.active_album) {
                        await this.setActiveAlbum(result.id);
                    }

                    this.showToast('Album created successfully!', 'success');
                    this.isAddingAlbum = false;
                } catch (e) {
                    this.showToast('Failed to create album: ' + e.message, 'error');
                }
            },

            startEditAlbum(album) {
                this.editingAlbumId = album.id;
                const urls = album.fallback_urls || [];
                const objUrls = urls.map((u, i) => ({ id: Date.now() + '_' + i + '_' + Math.random(), url: u }));
                this.editingAlbumData = { ...album, fallback_urls: objUrls };
                this.isAddingAlbum = false;
            },

            cancelEditAlbum() {
                this.editingAlbumId = null;
            },

            async saveEditAlbum() {
                if (!this.editingAlbumData.name.trim()) {
                    this.showToast('Please enter an album name.', 'warning');
                    return;
                }
                let normalizedImmich = '';
                if (this.editingAlbumData.immich_url && this.editingAlbumData.immich_url.trim()) {
                    normalizedImmich = this.normalizeHttpUrl(this.editingAlbumData.immich_url);
                    if (!normalizedImmich) {
                        this.showToast('Please enter a valid Immich share URL.', 'warning');
                        return;
                    }
                }
                let normalizedFallbacks = [];
                if (this.editingAlbumData.fallback_urls && this.editingAlbumData.fallback_urls.length > 0) {
                    for (const item of this.editingAlbumData.fallback_urls) {
                        const rawUrl = item ? item.url : '';
                        if (rawUrl && rawUrl.trim()) {
                            const normalized = this.normalizeHttpUrl(rawUrl);
                            if (!normalized) {
                                this.showToast('Invalid fallback URL found: ' + rawUrl, 'warning');
                                return;
                            }
                            normalizedFallbacks.push(normalized);
                        }
                    }
                }
                if (!normalizedImmich && normalizedFallbacks.length === 0) {
                    this.showToast('Please enter an Immich share URL or at least one fallback URL.', 'warning');
                    return;
                }
                const firstAmz = normalizedFallbacks.find(u => u.includes('amazon') || u.includes('/photos/share/')) || '';

                try {
                    await this.postAction('update_album', {
                        album_id: this.editingAlbumId,
                        name: this.editingAlbumData.name.trim(),
                        immich_url: normalizedImmich,
                        amazon_url: firstAmz || (normalizedFallbacks[0] || ''),
                        fallback_urls: normalizedFallbacks
                    });

                    const index = this.albums.findIndex(a => a.id === this.editingAlbumId);
                    if (index !== -1) {
                        this.albums[index] = {
                            id: this.editingAlbumId,
                            name: this.editingAlbumData.name.trim(),
                            immich_url: normalizedImmich,
                            amazon_url: firstAmz || (normalizedFallbacks[0] || ''),
                            fallback_urls: normalizedFallbacks,
                            order: this.albums[index].order
                        };
                    }

                    this.showToast('Album updated successfully!', 'success');
                    this.editingAlbumId = null;
                } catch (e) {
                    this.showToast('Failed to update album: ' + e.message, 'error');
                }
            },

            async deleteAlbum(albumId) {
                if (!confirm('Are you sure you want to delete this album?')) return;
                try {
                    await this.postAction('delete_album', { album_id: albumId });
                    
                    const wasActive = this.settings.active_album === albumId;
                    this.albums = this.albums.filter(a => a.id !== albumId);

                    if (wasActive) {
                        if (this.albums.length > 0) {
                            this.settings.active_album = this.albums[0].id;
                        } else {
                            this.settings.active_album = '';
                        }
                    }
                    this.showToast('Album deleted successfully!', 'success');
                } catch (e) {
                    this.showToast('Failed to delete album: ' + e.message, 'error');
                }
            },

            async moveAlbumUp(idx) {
                if (idx <= 0) return;
                await this.swapAlbums(idx, idx - 1);
            },

            async moveAlbumDown(idx) {
                if (idx >= this.albums.length - 1) return;
                await this.swapAlbums(idx, idx + 1);
            },

            moveFallbackUp(list, index) {
                if (index <= 0) return;
                const item = list[index];
                list.splice(index, 1);
                list.splice(index - 1, 0, item);
            },

            moveFallbackDown(list, index) {
                if (index >= list.length - 1) return;
                const item = list[index];
                list.splice(index, 1);
                list.splice(index + 1, 0, item);
            },

            async swapAlbums(i, j) {
                const albumA = this.albums[i];
                const albumB = this.albums[j];

                this.albums[i] = albumB;
                this.albums[j] = albumA;

                this.albums = [...this.albums];

                try {
                    await this.postAction('swap_albums', {
                        albumA_id: albumA.id,
                        albumA_order: j,
                        albumB_id: albumB.id,
                        albumB_order: i
                    });
                    
                    albumA.order = j;
                    albumB.order = i;
                    
                    this.showToast('Album order updated.', 'success', 800);
                } catch (e) {
                    this.showToast('Failed to save order: ' + e.message, 'error');
                }
            },

            async setActiveAlbum(albumId) {
                try {
                    await this.postAction('set_active_album', { album_id: albumId });
                    this.settings.active_album = albumId;
                    this.showToast('Active album updated!', 'success');
                } catch (e) {
                    this.showToast('Failed to update active album: ' + e.message, 'error');
                }
            },

            async saveSettings() {
                await this.performSave(true);
            },

            async applySettings() {
                await this.performSave(false);
            },

            async performSave(redirect) {
                try {
                    await this.postAction('save_settings', {
                        settings_id: this.settings.id,
                        color_primary: this.settings.color_primary,
                        color_accent: this.settings.color_accent,
                        color_background: this.settings.color_background,
                        randomize: !!this.settings.randomize,
                        prioritize_videos: !!this.settings.prioritize_videos,
                        autoplay_fullscreen: !!this.settings.autoplay_fullscreen,
                        latest_pin_count: parseInt(this.settings.latest_pin_count, 10) || 6,
                        slide_interval: parseInt(this.settings.slide_interval, 10) || 7,
                        video_repeat_threshold: parseInt(this.settings.video_repeat_threshold, 10) || 5,
                        video_repeat_count: parseInt(this.settings.video_repeat_count, 10) || 3,
                        cache_ttl: this.cacheTtlDays * 86400,
                        active_album: this.settings.active_album || null
                    });
                    this.showToast('Settings updated successfully!', 'success', 1200);
                    if (redirect) {
                        setTimeout(() => {
                            window.location.href = '/';
                        }, 500);
                    }
                } catch (e) {
                    this.showToast('Failed to update settings: ' + e.message, 'error');
                }
            }
        });
    }
</script>
