<div
    x-data="immichSlideshow()"
    class="fixed inset-0 w-screen h-screen bg-black overflow-hidden select-none"
    :class="{ 'cursor-none': !showControls }"
    @mousemove="keepControlsAlive()"
    @click="keepControlsAlive()"
    @touchstart="keepControlsAlive()"
>
    <!-- Background Image Layer (Blurred) & Foreground Image Layer -->
    <div class="absolute inset-0 w-full h-full z-0 overflow-hidden bg-black flex items-center justify-center">
        <template x-if="images.length > 0">
            <div class="absolute inset-0 w-full h-full">
                <!-- Blurred background -->
                <img
                    :src="images[currentIndex]"
                    alt=""
                    class="absolute inset-0 h-full w-full object-cover blur-3xl opacity-40 scale-110 pointer-events-none transition-all duration-700 ease-in-out"
                />
                <!-- Main sharp foreground image -->
                <img
                    :src="images[currentIndex]"
                    alt="Immich slideshow image"
                    class="relative h-full w-full object-contain z-10 transition-all duration-700 ease-in-out"
                />
            </div>
        </template>
        <template x-if="images.length === 0">
            <div class="flex h-full items-center justify-center px-6 text-center text-white z-10">
                <p class="max-w-2xl text-sm opacity-70" x-text="emptyMessage"></p>
            </div>
        </template>
    </div>

    <!-- Top Control Overlay -->
    <div
        x-show="showControls"
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="-translate-y-full opacity-0"
        x-transition:enter-end="translate-y-0 opacity-100"
        x-transition:leave="transition ease-in duration-300"
        x-transition:leave-start="translate-y-0 opacity-100"
        x-transition:leave-end="-translate-y-full opacity-0"
        class="absolute top-0 inset-x-0 p-6 z-20 flex justify-between items-start bg-gradient-to-b from-black/90 via-black/50 to-transparent pointer-events-none select-none text-white"
    >
        <div class="pointer-events-auto">
            <h1 class="text-xl font-bold tracking-tight text-white drop-shadow-md">
                Immich Slideshow
            </h1>
            <p class="text-xs opacity-75 drop-shadow-sm mt-0.5" x-text="statusText"></p>
        </div>
        <a
            href="/settings"
            class="pointer-events-auto border border-white/20 hover:border-white hover:bg-white/10 text-white rounded-xl px-4 py-2 text-sm font-semibold opacity-90 transition-all backdrop-blur-md shadow-lg drop-shadow-sm"
        >
            Settings
        </a>
    </div>

    <!-- Left Navigation Arrow -->
    <div
        x-show="showControls && images.length > 1"
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="-translate-x-8 opacity-0"
        x-transition:enter-end="translate-x-0 opacity-100"
        x-transition:leave="transition ease-in duration-300"
        x-transition:leave-start="translate-x-0 opacity-100"
        x-transition:leave-end="-translate-x-8 opacity-0"
        class="absolute left-6 top-1/2 -translate-y-1/2 z-20 pointer-events-auto"
    >
        <button
            @click="prevImage()"
            class="bg-black/40 hover:bg-black/60 text-white border border-white/10 w-14 h-14 flex items-center justify-center rounded-full backdrop-blur-md transition-all shadow-lg active:scale-95"
            title="Previous Image"
        >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" />
            </svg>
        </button>
    </div>

    <!-- Right Navigation Arrow -->
    <div
        x-show="showControls && images.length > 1"
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="translate-x-8 opacity-0"
        x-transition:enter-end="translate-x-0 opacity-100"
        x-transition:leave="transition ease-in duration-300"
        x-transition:leave-start="translate-x-0 opacity-100"
        x-transition:leave-end="translate-x-8 opacity-0"
        class="absolute right-6 top-1/2 -translate-y-1/2 z-20 pointer-events-auto"
    >
        <button
            @click="nextImage()"
            class="bg-black/40 hover:bg-black/60 text-white border border-white/10 w-14 h-14 flex items-center justify-center rounded-full backdrop-blur-md transition-all shadow-lg active:scale-95"
            title="Next Image"
        >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
            </svg>
        </button>
    </div>

    <!-- Bottom Control Overlay -->
    <div
        x-show="showControls && images.length > 0"
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="translate-y-full opacity-0"
        x-transition:enter-end="translate-y-0 opacity-100"
        x-transition:leave="transition ease-in duration-300"
        x-transition:leave-start="translate-y-0 opacity-100"
        x-transition:leave-end="translate-y-full opacity-0"
        class="absolute bottom-0 inset-x-0 p-6 z-20 flex justify-center items-center bg-gradient-to-t from-black/90 via-black/50 to-transparent pointer-events-none select-none text-white"
    >
        <div class="pointer-events-auto backdrop-blur-md bg-black/40 border border-white/10 px-5 py-2 rounded-full shadow-lg text-sm font-semibold tracking-wider drop-shadow-sm flex items-center gap-3">
            <span x-text="`${currentIndex + 1} / ${images.length}`"></span>
        </div>
    </div>

    <!-- Toast Notifications -->
    <div class="toast toast-end toast-bottom z-[200] pointer-events-auto">
        <template x-for="toast in toasts" :key="toast.id">
            <div :class="`alert ${toastAlertClass(toast.type)} shadow-lg`">
                <span x-text="toast.message"></span>
                <button
                    @click="removeToast(toast.id)"
                    class="btn btn-ghost btn-xs"
                >
                    x
                </button>
            </div>
        </template>
    </div>
</div>

<script src="/js/toast-helper.js"></script>
<script>
    function immichSlideshow() {
        return window.withToastHelpers({
            shareUrl: '<%= (locals.data && locals.data.settings) ? locals.data.settings.search_engine : "" %>',
            images: <%- JSON.stringify(data.images || []) %>,
            currentIndex: 0,
            statusText: '<%= data.statusText || "Loading slideshow..." %>',
            emptyMessage: 'No images loaded. Add an Immich share URL in Settings to start the slideshow.',
            slideTimerId: null,
            slideIntervalMs: 7000,
            showControls: true,
            controlsTimeout: null,

            init() {
                this.keepControlsAlive()
                if (this.images.length > 0) {
                    this.resetSlideshowTimer()
                } else {
                    this.emptyMessage = 'Could not read images from the share URL. Check URL validity and cross-origin permissions.'
                    this.showToast('Failed to load images from Immich share URL.', 'error')
                }
            },

            keepControlsAlive() {
                this.showControls = true
                if (this.controlsTimeout) {
                    clearTimeout(this.controlsTimeout)
                }
                this.controlsTimeout = setTimeout(() => {
                    this.showControls = false
                }, 3000)
            },

            resetSlideshowTimer() {
                if (this.slideTimerId) {
                    clearInterval(this.slideTimerId)
                    this.slideTimerId = null
                }

                if (this.images.length > 1) {
                    this.slideTimerId = setInterval(
                        () => this.nextImage(),
                        this.slideIntervalMs
                    )
                }
            },

            nextImage() {
                if (this.images.length <= 1) return
                this.currentIndex = (this.currentIndex + 1) % this.images.length
            },

            prevImage() {
                if (this.images.length <= 1) return
                this.currentIndex =
                    (this.currentIndex - 1 + this.images.length) %
                    this.images.length
            },
        })
    }
</script>
