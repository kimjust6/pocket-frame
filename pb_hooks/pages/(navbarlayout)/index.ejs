<div
    x-data="immichSlideshow()"
    class="mx-auto flex min-h-screen w-full max-w-6xl flex-col px-4 py-8 md:py-12"
>
    <header class="mb-6 flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-[color:var(--color-primary)]">
                Immich Slideshow
            </h1>
            <p class="text-xs opacity-60" x-text="statusText"></p>
        </div>
        <a
            href="/settings"
            class="border-[color:var(--color-primary)]/20 rounded-xl border px-4 py-2 text-sm font-semibold opacity-80 transition-all hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
        >
            Settings
        </a>
    </header>

    <main class="relative flex-1">
        <div
            class="border-[color:var(--color-primary)]/15 bg-[color:var(--color-primary)]/5 relative h-[70vh] w-full overflow-hidden rounded-2xl border"
        >
            <template x-if="images.length > 0">
                <img
                    :src="images[currentIndex]"
                    alt="Immich slideshow image"
                    class="h-full w-full object-contain"
                />
            </template>

            <div
                x-show="images.length === 0"
                class="flex h-full items-center justify-center px-6 text-center"
            >
                <p
                    class="max-w-2xl text-sm opacity-70"
                    x-text="emptyMessage"
                ></p>
            </div>

            <button
                x-show="images.length > 1"
                @click="prevImage()"
                class="bg-[color:var(--color-background)]/70 absolute left-3 top-1/2 -translate-y-1/2 rounded-full px-3 py-2 text-lg"
                title="Previous"
            >
                <
            </button>
            <button
                x-show="images.length > 1"
                @click="nextImage()"
                class="bg-[color:var(--color-background)]/70 absolute right-3 top-1/2 -translate-y-1/2 rounded-full px-3 py-2 text-lg"
                title="Next"
            >
                >
            </button>
        </div>
    </main>

    <div class="mt-4 text-center text-xs opacity-60">
        <span
            x-text="images.length > 0 ? `${currentIndex + 1} / ${images.length}` : ''"
        ></span>
    </div>

    <div class="toast toast-end toast-bottom z-[100]">
        <template x-for="toast in toasts" :key="toast.id">
            <div :class="`alert ${toastAlertClass(toast.type)} shadow-lg`">
                <span x-text="toast.message"></span>
                <button
                    @click="removeToast(toast.id)"
                    class="btn btn-ghost btn-xs"
                >
                    x
                </button>
            </div>
        </template>
    </div>
</div>

<script src="/js/toast-helper.js"></script>
<script>
    function immichSlideshow() {
        return window.withToastHelpers({
            shareUrl:
                '<%= locals.settings ? locals.settings.search_engine : "" %>',
            images: [],
            currentIndex: 0,
            statusText: 'Loading slideshow...',
            emptyMessage:
                'No images loaded. Add an Immich share URL in Settings to start the slideshow.',
            slideTimerId: null,
            slideIntervalMs: 7000,

            init() {
                this.start()
            },

            normalizeHttpUrl(rawValue) {
                if (typeof rawValue !== 'string' || !rawValue.trim()) return ''
                const trimmed = rawValue.trim()
                const withScheme = /^[a-zA-Z][a-zA-Z\d+\-.]*:\/\//.test(trimmed)
                    ? trimmed
                    : `https://${trimmed}`

                try {
                    const parsed = new URL(withScheme)
                    if (
                        parsed.protocol !== 'http:' &&
                        parsed.protocol !== 'https:'
                    )
                        return ''
                    return parsed.toString()
                } catch (_) {
                    return ''
                }
            },

            parseShareInfo(urlValue) {
                const normalized = this.normalizeHttpUrl(urlValue)
                if (!normalized) return null

                const parsed = new URL(normalized)
                const parts = parsed.pathname.split('/').filter(Boolean)
                const shareIndex = parts.indexOf('share')
                if (shareIndex === -1 || !parts[shareIndex + 1]) return null

                return {
                    origin: parsed.origin,
                    shareKey: parts[shareIndex + 1],
                }
            },

            async fetchJson(url, headers = {}) {
                const response = await fetch(url, { headers })
                if (!response.ok) return null
                const contentType = response.headers.get('content-type') || ''
                if (!contentType.includes('application/json')) return null
                return response.json()
            },

            collectAssetIds(value, bucket) {
                if (!value || typeof value !== 'object') return

                if (Array.isArray(value)) {
                    value.forEach((item) => this.collectAssetIds(item, bucket))
                    return
                }

                if (typeof value.id === 'string') {
                    const type =
                        typeof value.type === 'string'
                            ? value.type.toUpperCase()
                            : ''
                    if (!type || type === 'IMAGE') {
                        bucket.add(value.id)
                    }
                }

                for (const key of Object.keys(value)) {
                    this.collectAssetIds(value[key], bucket)
                }
            },

            async loadImageBlobUrl(origin, shareKey, assetId) {
                const candidates = [
                    {
                        url: `${origin}/api/assets/${assetId}/original`,
                        headers: { 'x-share-key': shareKey },
                    },
                    {
                        url: `${origin}/api/assets/${assetId}/thumbnail?size=preview`,
                        headers: { 'x-share-key': shareKey },
                    },
                    {
                        url: `${origin}/api/assets/${assetId}/thumbnail`,
                        headers: { 'x-share-key': shareKey },
                    },
                    {
                        url: `${origin}/api/assets/${assetId}/original?key=${encodeURIComponent(shareKey)}`,
                        headers: {},
                    },
                    {
                        url: `${origin}/api/assets/${assetId}/thumbnail?key=${encodeURIComponent(shareKey)}&size=preview`,
                        headers: {},
                    },
                    {
                        url: `${origin}/api/assets/${assetId}/thumbnail?key=${encodeURIComponent(shareKey)}`,
                        headers: {},
                    },
                ]

                for (const candidate of candidates) {
                    try {
                        const response = await fetch(candidate.url, {
                            headers: candidate.headers,
                        })
                        if (!response.ok) continue
                        const type = response.headers.get('content-type') || ''
                        if (!type.startsWith('image/')) continue
                        const blob = await response.blob()
                        return URL.createObjectURL(blob)
                    } catch (_) {
                        // Continue to next candidate.
                    }
                }

                return null
            },

            async fetchSharePayload(origin, shareKey) {
                const encodedKey = encodeURIComponent(shareKey)
                const calls = [
                    () =>
                        this.fetchJson(
                            `${origin}/api/shared-links/me?key=${encodedKey}`
                        ),
                    () =>
                        this.fetchJson(
                            `${origin}/api/shared-links/${encodedKey}`
                        ),
                    () =>
                        this.fetchJson(`${origin}/api/shared-links/me`, {
                            'x-share-key': shareKey,
                        }),
                    () =>
                        this.fetchJson(`${origin}/api/shared-links`, {
                            'x-share-key': shareKey,
                        }),
                ]

                for (const call of calls) {
                    try {
                        const payload = await call()
                        if (payload) return payload
                    } catch (_) {
                        // Continue to next endpoint.
                    }
                }

                return null
            },

            async fetchOgImageFallback(urlValue) {
                try {
                    const response = await fetch(urlValue)
                    if (!response.ok) return []
                    const html = await response.text()
                    const match =
                        html.match(
                            /<meta[^>]+property=["']og:image["'][^>]+content=["']([^"']+)["']/i
                        ) ||
                        html.match(
                            /<meta[^>]+content=["']([^"']+)["'][^>]+property=["']og:image["']/i
                        )
                    if (!match || !match[1]) return []
                    return [match[1]]
                } catch (_) {
                    return []
                }
            },

            resetSlideshowTimer() {
                if (this.slideTimerId) {
                    clearInterval(this.slideTimerId)
                    this.slideTimerId = null
                }

                if (this.images.length > 1) {
                    this.slideTimerId = setInterval(
                        () => this.nextImage(),
                        this.slideIntervalMs
                    )
                }
            },

            nextImage() {
                if (this.images.length <= 1) return
                this.currentIndex = (this.currentIndex + 1) % this.images.length
            },

            prevImage() {
                if (this.images.length <= 1) return
                this.currentIndex =
                    (this.currentIndex - 1 + this.images.length) %
                    this.images.length
            },

            async start() {
                const info = this.parseShareInfo(this.shareUrl)
                if (!info) {
                    this.statusText = 'No valid Immich share URL configured.'
                    this.emptyMessage =
                        'Open Settings and set a full Immich share URL.'
                    return
                }

                const payload = await this.fetchSharePayload(
                    info.origin,
                    info.shareKey
                )
                const assetIds = new Set()
                if (payload) {
                    this.collectAssetIds(payload, assetIds)
                }

                const loadedImages = []
                for (const assetId of assetIds) {
                    const imageUrl = await this.loadImageBlobUrl(
                        info.origin,
                        info.shareKey,
                        assetId
                    )
                    if (imageUrl) {
                        loadedImages.push(imageUrl)
                    }
                }

                if (loadedImages.length === 0) {
                    const fallback = await this.fetchOgImageFallback(
                        this.shareUrl
                    )
                    loadedImages.push(...fallback)
                }

                this.images = loadedImages
                this.currentIndex = 0

                if (this.images.length > 0) {
                    this.statusText = `Loaded ${this.images.length} image${this.images.length === 1 ? '' : 's'} from Immich.`
                    this.resetSlideshowTimer()
                } else {
                    this.statusText = 'Unable to load images from Immich.'
                    this.emptyMessage =
                        'Could not read images from the share URL. Check URL validity and cross-origin permissions.'
                    this.showToast(
                        'Failed to load images from Immich share URL.',
                        'error'
                    )
                }
            },
        })
    }
</script>
