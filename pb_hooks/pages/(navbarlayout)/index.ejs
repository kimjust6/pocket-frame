<div
    x-data="immichSlideshow()"
    class="fixed inset-0 w-screen h-screen bg-black overflow-hidden select-none"
    :class="{ 'cursor-none': !showControls }"
    @mousemove="keepControlsAlive()"
    @click="keepControlsAlive()"
    @touchstart="onTouchStart($event); keepControlsAlive()"
    @touchmove="onTouchMove($event)"
    @touchend="onTouchEnd($event)"
    @keydown.window.left="prevImage(); keepControlsAlive()"
    @keydown.window.right="nextImage(); keepControlsAlive()"
>
    <!-- Slideshow Track Wrapper -->
    <div 
        x-show="images.length > 0"
        class="absolute inset-0 flex"
        :class="(isSwiping || !shouldAnimate) ? '' : 'transition-transform duration-500 ease-out'"
        :style="`transform: translateX(calc(-${currentIndex * 100}% + ${swipeOffset}px))`"
    >
        <template x-for="(img, idx) in images" :key="idx">
            <div class="w-screen h-screen flex-shrink-0 relative overflow-hidden bg-black flex items-center justify-center">
                <template x-if="isNear(idx) || loadedIndices.includes(idx)">
                    <div class="absolute inset-0 w-full h-full flex items-center justify-center">
                        <!-- Blurred background -->
                        <img
                            :src="loadedIndices.includes(idx) ? img.thumbnailUrl : ''"
                            alt=""
                            class="absolute inset-0 h-full w-full object-cover blur-3xl opacity-40 scale-110 pointer-events-none"
                            loading="lazy"
                            referrerpolicy="no-referrer"
                        />
                        <!-- Foreground Image -->
                        <img
                            x-show="img.type === 'IMAGE'"
                            :src="(img.type === 'IMAGE' && loadedIndices.includes(idx)) ? img.url : ''"
                            :id="`image-${idx}`"
                            alt="Immich slideshow image"
                            class="relative h-full w-full object-contain z-10"
                            referrerpolicy="no-referrer"
                        />
                        <!-- Foreground Video -->
                        <video
                            x-show="img.type === 'VIDEO'"
                            :src="(img.type === 'VIDEO' && idx === currentIndex) ? img.url : ''"
                            :id="`video-${idx}`"
                            preload="auto"
                            muted
                            playsinline
                            controls
                            @canplay="if (idx === currentIndex) { const v = $event.target; v.muted = true; setTimeout(() => { v.play().then(() => { v.muted = false }).catch(() => { v.muted = false }) }, 150) }"
                            @ended="onVideoEnded($event)"
                            class="relative h-full w-full object-contain z-10 pointer-events-auto"
                            referrerpolicy="no-referrer"
                        ></video>
                    </div>
                </template>
            </div>
        </template>
    </div>
    <div x-show="images.length === 0" class="absolute inset-0 flex items-center justify-center px-6 text-center text-white z-10">
        <p class="max-w-2xl text-sm opacity-70" x-text="emptyMessage"></p>
    </div>

    <!-- Top Control Overlay -->
    <div
        x-show="showControls"
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="-translate-y-full opacity-0"
        x-transition:enter-end="translate-y-0 opacity-100"
        x-transition:leave="transition ease-in duration-300"
        x-transition:leave-start="translate-y-0 opacity-100"
        x-transition:leave-end="-translate-y-full opacity-0"
        class="absolute top-0 inset-x-0 p-6 z-20 flex justify-between items-start bg-gradient-to-b from-black/90 via-black/50 to-transparent pointer-events-none select-none text-white"
    >
        <a href="/" class="pointer-events-auto cursor-pointer block hover:opacity-90 select-none">
            <h1 class="text-xl font-bold tracking-tight text-white drop-shadow-md">
                <%= (locals.data && locals.data.albumName) ? locals.data.albumName : "Pocket Frame" %>
            </h1>
            <p class="text-xs opacity-75 drop-shadow-sm mt-0.5" x-text="statusText"></p>
        </a>
        <div class="flex items-center gap-3 pointer-events-auto">
            <button
                @click="toggleFullscreen()"
                class="border border-white/20 hover:border-white hover:bg-white/10 text-white rounded-xl px-4 py-2 text-sm font-semibold opacity-90 transition-all backdrop-blur-md shadow-lg drop-shadow-sm flex items-center gap-2"
                title="Toggle Fullscreen"
            >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" :d="isFullscreen ? 'M4 4h4v4H4zm12 0h4v4h-4zM4 16h4v4H4zm12 0h4v4h-4z' : 'M4 8V4h4M16 4h4v4M4 16v4h4M20 16v4h-4'" />
                </svg>
                <span x-text="isFullscreen ? 'Exit Fullscreen' : 'Fullscreen'"></span>
            </button>
            <a
                href="/settings"
                class="border border-white/20 hover:border-white hover:bg-white/10 text-white rounded-xl px-4 py-2 text-sm font-semibold opacity-90 transition-all backdrop-blur-md shadow-lg drop-shadow-sm"
            >
                Settings
            </a>
        </div>
    </div>

    <!-- Left Navigation Arrow -->
    <div
        x-show="showControls && images.length > 1"
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="-translate-x-8 opacity-0"
        x-transition:enter-end="translate-x-0 opacity-100"
        x-transition:leave="transition ease-in duration-300"
        x-transition:leave-start="translate-x-0 opacity-100"
        x-transition:leave-end="-translate-x-8 opacity-0"
        class="absolute left-6 top-1/2 -translate-y-1/2 z-20 pointer-events-auto"
    >
        <button
            @click="prevImage()"
            class="bg-black/40 hover:bg-black/60 text-white border border-white/10 w-14 h-14 flex items-center justify-center rounded-full backdrop-blur-md transition-all shadow-lg active:scale-95"
            title="Previous Image"
        >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" />
            </svg>
        </button>
    </div>

    <!-- Right Navigation Arrow -->
    <div
        x-show="showControls && images.length > 1"
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="translate-x-8 opacity-0"
        x-transition:enter-end="translate-x-0 opacity-100"
        x-transition:leave="transition ease-in duration-300"
        x-transition:leave-start="translate-x-0 opacity-100"
        x-transition:leave-end="translate-x-8 opacity-0"
        class="absolute right-6 top-1/2 -translate-y-1/2 z-20 pointer-events-auto"
    >
        <button
            @click="nextImage()"
            class="bg-black/40 hover:bg-black/60 text-white border border-white/10 w-14 h-14 flex items-center justify-center rounded-full backdrop-blur-md transition-all shadow-lg active:scale-95"
            title="Next Image"
        >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
            </svg>
        </button>
    </div>

    <!-- Bottom Control Overlay -->
    <div
        x-show="showControls && images.length > 0"
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="translate-y-full opacity-0"
        x-transition:enter-end="translate-y-0 opacity-100"
        x-transition:leave="transition ease-in duration-300"
        x-transition:leave-start="translate-y-0 opacity-100"
        x-transition:leave-end="translate-y-full opacity-0"
        class="absolute bottom-0 inset-x-0 p-6 z-20 flex justify-center items-center bg-gradient-to-t from-black/90 via-black/50 to-transparent pointer-events-none select-none text-white"
    >
        <div class="pointer-events-auto backdrop-blur-md bg-black/40 border border-white/10 px-5 py-2 rounded-full shadow-lg text-sm font-semibold tracking-wider drop-shadow-sm flex items-center gap-3">
            <span x-text="`${currentIndex + 1} / ${images.length}`"></span>
        </div>
    </div>

    <!-- Toast Notifications -->
    <div class="toast toast-end toast-bottom z-[200] pointer-events-auto">
        <template x-for="toast in toasts" :key="toast.id">
            <div :class="`alert ${toastAlertClass(toast.type)} shadow-lg`">
                <span x-text="toast.message"></span>
                <button
                    @click="removeToast(toast.id)"
                    class="btn btn-ghost btn-xs"
                >
                    x
                </button>
            </div>
        </template>
    </div>

    <!-- Autoplay Fullscreen Start Overlay -->
    <div 
        x-show="autoplayFullscreen && !isFullscreen"
        @click="toggleFullscreen()"
        class="fixed inset-0 z-[1000] bg-black/95 flex flex-col items-center justify-center cursor-pointer select-none text-white transition-all duration-500"
    >
        <div class="text-center space-y-4 max-w-sm p-6">
            <!-- Tap Icon -->
            <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mx-auto text-[color:var(--color-accent)] animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122" />
            </svg>
            <h2 class="text-xl font-bold tracking-tight">Tap to Start Kiosk Mode</h2>
            <p class="text-xs opacity-70">This will launch the Immich Slideshow in fullscreen.</p>
        </div>
    </div>
</div>

<script src="/js/toast-helper.js"></script>
<script>
    function immichSlideshow() {
        return window.withToastHelpers({
            shareUrl: '<%= (locals.data && locals.data.settings) ? locals.data.settings.search_engine : "" %>',
            images: <%- JSON.stringify(data.images || []) %>,
            currentIndex: 0,
            statusText: '<%= data.statusText || "Loading slideshow..." %>',
            emptyMessage: 'No images loaded. Add an Immich share URL in Settings to start the slideshow.',
            slideTimerId: null,
            slideIntervalMs: <%= (locals.data && locals.data.settings && locals.data.settings.slide_interval) ? locals.data.settings.slide_interval * 1000 : 7000 %>,
            showControls: true,
            controlsTimeout: null,
            videoRepeatThreshold: <%= (locals.data && locals.data.settings && locals.data.settings.video_repeat_threshold) ? locals.data.settings.video_repeat_threshold : 5 %>,
            videoRepeatCount: <%= (locals.data && locals.data.settings && locals.data.settings.video_repeat_count) ? locals.data.settings.video_repeat_count : 3 %>,
            currentVideoPlayCount: 0,
            isFullscreen: false,
            autoplayFullscreen: <%= (locals.data && locals.data.settings && locals.data.settings.autoplay_fullscreen) ? 'true' : 'false' %>,
            touchStartX: 0,
            touchEndX: 0,
            touchStartY: 0,
            touchEndY: 0,
            swipeOffset: 0,
            isSwiping: false,
            shouldAnimate: false,
            isFirstLoad: true,
            loadedIndices: [],

            isNear(idx) {
                const len = this.images.length;
                if (len <= 5) return true;
                const diff = Math.min(
                    Math.abs(idx - this.currentIndex),
                    len - Math.abs(idx - this.currentIndex)
                );
                return diff <= 2;
            },

            init() {
                this.keepControlsAlive()
                document.addEventListener('fullscreenchange', () => {
                    this.isFullscreen = !!document.fullscreenElement
                })
                if (this.images.length > 0) {
                    if (document.readyState === 'complete') {
                        this.onSlideChanged()
                    } else {
                        window.addEventListener('load', () => {
                            this.onSlideChanged()
                        })
                    }
                } else {
                    this.emptyMessage = 'No images loaded. Check that your share URL is valid and the photo server is reachable.'
                    this.showToast('Failed to load photos from share URL. Check the server logs for details.', 'error')
                }
            },

            keepControlsAlive() {
                this.showControls = true
                if (this.controlsTimeout) {
                    clearTimeout(this.controlsTimeout)
                }
                this.controlsTimeout = setTimeout(() => {
                    this.showControls = false
                }, 3000)
            },

            toggleFullscreen() {
                if (!document.fullscreenElement) {
                    document.documentElement.requestFullscreen().catch((err) => {
                        this.showToast('Error enabling fullscreen: ' + err.message, 'error')
                    })
                } else {
                    document.exitFullscreen()
                }
            },

            onTouchStart(e) {
                if (e.touches && e.touches.length > 0) {
                    const clientX = e.touches[0].clientX
                    const clientY = e.touches[0].clientY

                    // Ignore touch gestures on buttons, links, inputs, or near bottom controls zone
                    if (e.target && (
                        e.target.tagName === 'BUTTON' ||
                        e.target.tagName === 'A' ||
                        e.target.tagName === 'INPUT' ||
                        e.target.closest('a') ||
                        e.target.closest('button') ||
                        clientY > window.innerHeight - 100
                    )) {
                        this.isSwiping = false
                        return
                    }

                    this.isSwiping = true
                    this.touchStartX = clientX
                    this.touchStartY = clientY
                    this.swipeOffset = 0
                }
            },

            onTouchMove(e) {
                if (!this.isSwiping) return
                if (e.touches && e.touches.length > 0) {
                    const currentX = e.touches[0].clientX
                    const currentY = e.touches[0].clientY
                    const diffX = currentX - this.touchStartX
                    const diffY = currentY - this.touchStartY

                    // Only handle horizontal swipes
                    if (Math.abs(diffX) > Math.abs(diffY)) {
                        e.preventDefault()
                        this.swipeOffset = diffX
                    }
                }
            },

            onTouchEnd(e) {
                if (!this.isSwiping) return
                this.isSwiping = false
                this.shouldAnimate = true

                const threshold = window.innerWidth * 0.15 // 15% of viewport width
                if (this.swipeOffset < -threshold) {
                    this.nextImage()
                } else if (this.swipeOffset > threshold) {
                    this.prevImage()
                }
                this.swipeOffset = 0

                setTimeout(() => {
                    this.shouldAnimate = false
                }, 550)
            },

            markLoaded(index) {
                const len = this.images.length;
                if (len === 0) return;
                const prev = (index - 1 + len) % len;
                const next = (index + 1) % len;
                [prev, index, next].forEach(idx => {
                    if (!this.loadedIndices.includes(idx)) {
                        this.loadedIndices.push(idx);
                    }
                });
            },

            onSlideChanged() {
                this.markLoaded(this.currentIndex)
                this.currentVideoPlayCount = 0
                if (this.slideTimerId) {
                    clearInterval(this.slideTimerId)
                    this.slideTimerId = null
                }

                // Control video playback programmatically based on active index
                const tryPlayVideo = () => {
                    const videoElements = document.querySelectorAll('video')
                    videoElements.forEach((video) => {
                        const idx = parseInt(video.id.replace('video-', ''))
                        if (idx === this.currentIndex) {
                            if (video.paused) {
                                video.currentTime = 0
                                setTimeout(() => {
                                    if (idx === this.currentIndex && video.paused) {
                                        video.play().catch(() => {})
                                    }
                                }, 150)
                            }
                        } else {
                            if (!video.paused) {
                                video.pause()
                            }
                        }
                    })
                }
                this.$nextTick(() => {
                    tryPlayVideo()
                    // Retry after a short delay in case x-if hasn't rendered the video yet
                    setTimeout(tryPlayVideo, 150)
                })

                if (this.images.length <= 1) return

                const current = this.images[this.currentIndex]
                if (current.type === 'VIDEO') {
                    // Let the video end event transition to the next image automatically.
                    // We don't start the standard image slide timer.
                } else {
                    // Start timer for standard image slides
                    const startImageTimer = () => {
                        if (this.slideTimerId) {
                            clearInterval(this.slideTimerId)
                        }
                        let interval = this.slideIntervalMs
                        if (this.isFirstLoad) {
                            interval *= 2
                            this.isFirstLoad = false
                        }
                        this.slideTimerId = setInterval(
                            () => this.nextImage(),
                            interval
                        )
                    }

                    // Check if current image is loaded
                    this.$nextTick(() => {
                        const imgEl = document.getElementById(`image-${this.currentIndex}`)
                        if (imgEl) {
                            if (imgEl.complete && imgEl.naturalWidth !== 0) {
                                startImageTimer()
                            } else {
                                function onImageLoad() {
                                    startImageTimer()
                                    imgEl.removeEventListener('load', onImageLoad)
                                    imgEl.removeEventListener('error', onImageError)
                                }
                                function onImageError() {
                                    // Start the timer anyway, so the slideshow doesn't get stuck on a broken image
                                    startImageTimer()
                                    imgEl.removeEventListener('load', onImageLoad)
                                    imgEl.removeEventListener('error', onImageError)
                                }
                                imgEl.addEventListener('load', onImageLoad)
                                imgEl.addEventListener('error', onImageError)
                            }
                        } else {
                            startImageTimer()
                        }
                    })
                }
            },

            onVideoEnded(e) {
                const current = this.images[this.currentIndex]
                const duration = current.duration || (e.target ? Math.round(e.target.duration) : 0)

                if (duration > 0 && duration < this.videoRepeatThreshold) {
                    this.currentVideoPlayCount++
                    if (this.currentVideoPlayCount < this.videoRepeatCount) {
                        if (e.target) {
                            e.target.currentTime = 0
                            setTimeout(() => {
                                if (e.target.paused) {
                                    e.target.play().catch(() => {})
                                }
                            }, 150)
                        }
                        return
                    }
                }

                this.nextImage()
            },

            nextImage() {
                if (this.images.length <= 1) return
                this.isFirstLoad = false
                this.currentIndex = (this.currentIndex + 1) % this.images.length
                this.onSlideChanged()
            },

            prevImage() {
                if (this.images.length <= 1) return
                this.isFirstLoad = false
                this.currentIndex =
                    (this.currentIndex - 1 + this.images.length) %
                    this.images.length
                this.onSlideChanged()
            },
        })
    }
</script>
